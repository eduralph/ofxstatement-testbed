{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh workflow run:*)",
      "Bash(gh repo sync:*)",
      "Bash(gh auth status)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(./make.py:*)",
      "Bash(python make.py:*)",
      "Bash(python3 make.py:*)",
      "Bash(gramps:*)",
      "Bash(xvfb-run:*)",
      "Bash(dbus-run-session:*)",
      "Bash(dogtail-run-headless-next:*)",
      "Bash(gsettings:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(make:*)",
      "Bash(./scripts/**)",
      "Bash(bash scripts/**)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(tar:*)",
      "Bash(unzip:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(echo:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.ssh/**)",
      "Read(**/credentials*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Write(.env)",
      "Write(.env.*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git push --force*)",
      "Bash(rm:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh release:*)"
    ]
  }
}
